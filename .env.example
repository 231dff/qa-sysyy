# ============================================================
# 智能搜索助手 — 环境变量模板
# 复制此文件为 .env 并填入实际值
# ============================================================

# ── LLM API (兼容 OpenAI 协议) ──
LLM_API_KEY=sk-your-api-key-here
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3

# ── Tavily 搜索 API ──
TAVILY_API_KEY=tvly-your-api-key-here
TAVILY_API_BASE=https://api.tavily.com
